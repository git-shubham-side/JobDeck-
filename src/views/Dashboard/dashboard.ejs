<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>JobDeck | Student Dashboard</title>

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Google Fonts: Inter for a clean, modern look -->
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              sans: ["Inter", "sans-serif"],
            },
            colors: {
              brand: {
                50: "#eff6ff",
                100: "#dbeafe",
                500: "#3b82f6",
                600: "#2563eb",
                900: "#1e3a8a",
              },
            },
          },
        },
      };
    </script>
  </head>
  <body
    class="bg-gray-50 text-gray-800 font-sans antialiased flex h-screen overflow-hidden"
  >
    <!-- Sidebar -->
    <aside
      class="w-64 bg-white border-r border-gray-200 hidden md:flex flex-col"
    >
      <!-- Logo -->
      <div class="h-16 flex items-center px-6 border-b border-gray-100">
        <div class="flex items-center gap-2 text-brand-600 font-bold text-xl">
          <i data-lucide="layers" class="w-6 h-6"></i>
          JobDeck
        </div>
      </div>

      <!-- Navigation -->
      <nav class="flex-1 px-4 py-6 space-y-2 overflow-y-auto">
        <a
          href="#"
          class="flex items-center gap-3 px-3 py-2.5 bg-brand-50 text-brand-600 rounded-lg font-medium transition-colors"
        >
          <i data-lucide="layout-dashboard" class="w-5 h-5"></i> Dashboard
        </a>
        <a
          href="#"
          class="flex items-center gap-3 px-3 py-2.5 text-gray-500 hover:text-gray-900 hover:bg-gray-100 rounded-lg font-medium transition-colors"
        >
          <i data-lucide="search" class="w-5 h-5"></i> Find Jobs
        </a>
        <a
          href="#"
          class="flex items-center gap-3 px-3 py-2.5 text-gray-500 hover:text-gray-900 hover:bg-gray-100 rounded-lg font-medium transition-colors"
        >
          <i data-lucide="briefcase" class="w-5 h-5"></i> My Applications
        </a>
        <a
          href="#"
          class="flex items-center gap-3 px-3 py-2.5 text-gray-500 hover:text-gray-900 hover:bg-gray-100 rounded-lg font-medium transition-colors"
        >
          <i data-lucide="bookmark" class="w-5 h-5"></i> Saved
        </a>
      </nav>

      <!-- Bottom Profile -->
      <div class="p-4 border-t border-gray-100">
        <a
          href="#"
          class="flex items-center gap-3 px-3 py-2 text-gray-500 hover:text-gray-900 hover:bg-gray-100 rounded-lg transition-colors"
        >
          <i data-lucide="settings" class="w-5 h-5"></i> Settings
        </a>
      </div>
    </aside>

    <!-- Main Content -->
    <div class="flex-1 flex flex-col overflow-hidden">
      <!-- Header -->
      <header
        class="h-16 bg-white border-b border-gray-200 flex items-center justify-between px-6 lg:px-10 z-10"
      >
        <!-- Mobile Menu Button -->
        <button class="md:hidden text-gray-500 hover:text-gray-900">
          <i data-lucide="menu" class="w-6 h-6"></i>
        </button>

        <!-- Search Bar -->
        <div
          class="hidden sm:flex items-center bg-gray-100 rounded-lg px-3 py-2 w-96 border border-transparent focus-within:border-brand-500 focus-within:bg-white transition-all"
        >
          <i data-lucide="search" class="w-4 h-4 text-gray-400"></i>
          <input
            type="text"
            placeholder="Search for internships, roles, companies..."
            class="bg-transparent border-none outline-none ml-2 w-full text-sm text-gray-700 placeholder-gray-400"
          />
        </div>

        <!-- Header Right -->
        <div class="flex items-center gap-5">
          <button
            class="relative text-gray-400 hover:text-gray-600 transition-colors"
          >
            <i data-lucide="bell" class="w-5 h-5"></i>
            <span
              class="absolute top-0 right-0 w-2 h-2 bg-red-500 rounded-full border border-white"
            ></span>
          </button>
          <div
            class="w-8 h-8 rounded-full bg-brand-600 text-white flex items-center justify-center font-semibold text-sm shadow-sm cursor-pointer"
          >
            <!-- EJS Dynamic Variable Example -->
            <%= typeof user !== 'undefined' ? user.name.charAt(0) : 'S' %>
          </div>
        </div>
      </header>

      <!-- Scrollable Dashboard Content -->
      <main class="flex-1 overflow-y-auto p-6 lg:p-10">
        <div class="mb-8 flex justify-between items-end">
          <div>
            <h1 class="text-2xl font-bold text-gray-900">
              Welcome <%= user.lastName => back, <%= typeof user !== 'undefined'
              ? user.firstName : 'Student' %>!
            </h1>
            <p class="text-gray-500 text-sm mt-1">
              Here is what's happening with your job applications today.
            </p>
          </div>
          <button
            class="hidden sm:flex items-center gap-2 bg-brand-600 hover:bg-brand-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors shadow-sm"
          >
            <i data-lucide="plus" class="w-4 h-4"></i> Upload Resume
          </button>
        </div>

        <!-- Stats Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
          <div
            class="bg-white p-5 rounded-xl border border-gray-200 shadow-sm flex items-center gap-4"
          >
            <div
              class="w-12 h-12 rounded-lg bg-blue-50 text-blue-600 flex items-center justify-center"
            >
              <i data-lucide="send" class="w-6 h-6"></i>
            </div>
            <div>
              <p class="text-sm text-gray-500 font-medium">Total Applied</p>
              <h3 class="text-2xl font-bold text-gray-900">0</h3>
            </div>
          </div>
          <div
            class="bg-white p-5 rounded-xl border border-gray-200 shadow-sm flex items-center gap-4"
          >
            <div
              class="w-12 h-12 rounded-lg bg-amber-50 text-amber-600 flex items-center justify-center"
            >
              <i data-lucide="clock" class="w-6 h-6"></i>
            </div>
            <div>
              <p class="text-sm text-gray-500 font-medium">In Review</p>
              <h3 class="text-2xl font-bold text-gray-900">0</h3>
            </div>
          </div>
          <div
            class="bg-white p-5 rounded-xl border border-gray-200 shadow-sm flex items-center gap-4"
          >
            <div
              class="w-12 h-12 rounded-lg bg-emerald-50 text-emerald-600 flex items-center justify-center"
            >
              <i data-lucide="check-circle" class="w-6 h-6"></i>
            </div>
            <div>
              <p class="text-sm text-gray-500 font-medium">Interviews</p>
              <h3 class="text-2xl font-bold text-gray-900">0</h3>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          <!-- Left Column: Recommended Jobs -->
          <div class="lg:col-span-2 space-y-6">
            <div class="flex items-center justify-between">
              <h2 class="text-lg font-bold text-gray-900">
                Recommended for you
              </h2>
              <a
                href="#"
                class="text-sm font-medium text-brand-600 hover:text-brand-700"
                >View all</a
              >
            </div>

            <div class="grid gap-4">
              <!-- Job Card 1 -->
              <div
                class="bg-white p-5 rounded-xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow group flex flex-col sm:flex-row sm:items-center justify-between gap-4"
              >
                <div class="flex items-start gap-4">
                  <div
                    class="w-12 h-12 rounded-lg bg-gray-100 flex items-center justify-center flex-shrink-0"
                  >
                    <i data-lucide="figma" class="w-6 h-6 text-gray-700"></i>
                  </div>
                  <div>
                    <h3
                      class="font-semibold text-gray-900 group-hover:text-brand-600 transition-colors"
                    >
                      UI/UX Design Intern
                    </h3>
                    <p class="text-sm text-gray-500 mt-0.5">Figma • Remote</p>
                    <div class="flex gap-2 mt-2">
                      <span
                        class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-gray-100 text-gray-600"
                        >Internship</span
                      >
                      <span
                        class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-green-50 text-green-700"
                        >$3k - $4k/mo</span
                      >
                    </div>
                  </div>
                </div>
                <button
                  class="w-full sm:w-auto px-4 py-2 border border-gray-200 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50 hover:text-brand-600 hover:border-brand-200 transition-all"
                >
                  Apply Now
                </button>
              </div>

              <!-- Job Card 2 -->
              <div
                class="bg-white p-5 rounded-xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow group flex flex-col sm:flex-row sm:items-center justify-between gap-4"
              >
                <div class="flex items-start gap-4">
                  <div
                    class="w-12 h-12 rounded-lg bg-gray-100 flex items-center justify-center flex-shrink-0"
                  >
                    <i data-lucide="database" class="w-6 h-6 text-gray-700"></i>
                  </div>
                  <div>
                    <h3
                      class="font-semibold text-gray-900 group-hover:text-brand-600 transition-colors"
                    >
                      Frontend Developer
                    </h3>
                    <p class="text-sm text-gray-500 mt-0.5">
                      Stripe • San Francisco, CA
                    </p>
                    <div class="flex gap-2 mt-2">
                      <span
                        class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-gray-100 text-gray-600"
                        >Full-time</span
                      >
                      <span
                        class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-green-50 text-green-700"
                        >Entry Level</span
                      >
                    </div>
                  </div>
                </div>
                <button
                  class="w-full sm:w-auto px-4 py-2 border border-gray-200 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50 hover:text-brand-600 hover:border-brand-200 transition-all"
                >
                  Apply Now
                </button>
              </div>
            </div>
          </div>

          <!-- Right Column: Application Tracker -->
          <div class="space-y-6">
            <div class="flex items-center justify-between">
              <h2 class="text-lg font-bold text-gray-900">
                Application Status
              </h2>
            </div>

            <div
              class="bg-white rounded-xl border border-gray-200 shadow-sm p-1"
            >
              <!-- Tracker Item 1 -->
              <div
                class="p-4 flex items-center justify-between border-b border-gray-100 last:border-0 hover:bg-gray-50 transition-colors rounded-lg"
              >
                <div>
                  <h4 class="text-sm font-semibold text-gray-900">
                    Software Engineer Intern
                  </h4>
                  <p class="text-xs text-gray-500 mt-0.5">Google</p>
                </div>
                <span
                  class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-blue-50 text-blue-700"
                >
                  <span class="w-1.5 h-1.5 rounded-full bg-blue-600"></span>
                  Interview
                </span>
              </div>

              <!-- Tracker Item 2 -->
              <div
                class="p-4 flex items-center justify-between border-b border-gray-100 last:border-0 hover:bg-gray-50 transition-colors rounded-lg"
              >
                <div>
                  <h4 class="text-sm font-semibold text-gray-900">
                    Product Designer
                  </h4>
                  <p class="text-xs text-gray-500 mt-0.5">Spotify</p>
                </div>
                <span
                  class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-amber-50 text-amber-700"
                >
                  <span class="w-1.5 h-1.5 rounded-full bg-amber-600"></span>
                  In Review
                </span>
              </div>

              <!-- Tracker Item 3 -->
              <div
                class="p-4 flex items-center justify-between border-b border-gray-100 last:border-0 hover:bg-gray-50 transition-colors rounded-lg"
              >
                <div>
                  <h4 class="text-sm font-semibold text-gray-900">
                    Marketing Intern
                  </h4>
                  <p class="text-xs text-gray-500 mt-0.5">Netflix</p>
                </div>
                <span
                  class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-600"
                >
                  <span class="w-1.5 h-1.5 rounded-full bg-gray-500"></span>
                  Applied
                </span>
              </div>
            </div>

            <button
              class="w-full py-2.5 bg-white border border-gray-200 text-gray-600 rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors shadow-sm"
            >
              View All Activity
            </button>
          </div>
        </div>
      </main>
    </div>

    <!-- Initialize Lucide Icons -->
    <script>
      lucide.createIcons();
    </script>
  </body>
</html>
