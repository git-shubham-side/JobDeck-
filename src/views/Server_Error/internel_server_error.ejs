<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="../public/logoImage/JD-logo.png">
    <link rel="stylesheet" href="../../Server_ERROR_CSS/server-error.css">
    <title>500 - Internal Server Error</title>
   
</head>
<body>

    <div class="container">
        <div class="error-code">500</div>
        <h1>Oops! Something went wrong</h1>
        <p>Our servers are having a momentary meltdown. We're already looking into it, so please try refreshing the page or come back later.</p>
        
        <a href="/" class="btn">Take Me Home</a>

        <% if (locals.error && process.env.NODE_ENV !== 'production') { %>
            <div class="debug-box">
                <div class="debug-title">Developer Error Logs:</div>
                <pre><%= err.message %></pre>
                <% if (err.stack) { %>
                    <pre style="color: #94a3b8; margin-top: 8px;"><%= err.stack %></pre>
                <% } %>
            </div>
        <% } %>
    </div>

</body>
</html>